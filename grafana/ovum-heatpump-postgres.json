          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT now() AS \"time\", COUNT(*) AS \"Starts\"\nFROM (\n  SELECT\n    inverter_rps,\n    LAG(inverter_rps) OVER (ORDER BY recorded_at) AS prev_rps\n  FROM heatpump_readings\n  WHERE sensor_id = 'ovum_heatpump'\n    AND $__timeFilter(recorded_at)\n) sub\nWHERE (prev_rps IS NULL OR prev_rps = 0) AND inverter_rps > 0",
          "refId": "A"
        }
      ],
      "title": "Number of Starts",
      "type": "stat"
    },
