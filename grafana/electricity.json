        {
          "dataset": "helius",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PDE6A885CF4E31BBE"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  SUM(power_w * seconds_to_next) / 3600000.0 AS energy_kwh\nFROM (\n  SELECT\n    power_w,\n    EXTRACT(EPOCH FROM (\n      LEAD(recorded_at) OVER (ORDER BY recorded_at) - recorded_at\n    )) AS seconds_to_next\n  FROM\n    energy_readings\n  WHERE\n    sensor_id = 'solar_balcony'\n    AND recorded_at >= DATE_TRUNC('day', NOW())\n    AND recorded_at <= NOW()\n    AND power_w IS NOT NULL\n) sub\nWHERE\n  seconds_to_next IS NOT NULL",
          "refId": "B",
          "sql": {
            "columns": [{ "parameters": [], "type": "function" }],
            "groupBy": [
