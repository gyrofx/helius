          "rawSql": "SELECT\n  $__timeGroupAlias(recorded_at, $__interval),\n  AVG(power_w) AS \"Power\"\nFROM\n  energy_readings\nWHERE\n  sensor_id = 'solar_balcony'\n  AND $__timeFilter(recorded_at)\n  AND power_w IS NOT NULL\nGROUP BY 1\nORDER BY 1 ASC\n",
          "refId": "A",
