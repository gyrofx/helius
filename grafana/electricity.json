          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  hour AS \"time\",\n  SUM(delta_wh) / 1000.0 AS \"kWh\"\nFROM (\n  SELECT\n    channel,\n    hour,\n    GREATEST(0, last_wh - LAG(last_wh) OVER (PARTITION BY channel ORDER BY hour)) AS delta_wh\n  FROM (\n    SELECT\n      channel,\n      DATE_TRUNC('hour', recorded_at) AS hour,\n      MAX(energy_wh) AS last_wh\n    FROM energy_readings\n    WHERE\n      sensor_id = 'shelly_em3_main'\n      AND energy_wh IS NOT NULL\n      AND $__timeFilter(recorded_at)\n    GROUP BY channel, DATE_TRUNC('hour', recorded_at)\n  ) hourly\n) deltas\nWHERE delta_wh IS NOT NULL\nGROUP BY hour\nORDER BY hour ASC",
          "refId": "A"
        }
      ],
      "title": "Strom Verlauf",
      "type": "barchart"
